{
  "name": "iconforge",
  "displayName": "IconForge",
  "description": "Get all free icons in one place. Search, customize, and insert thousands of premium SVG icons directly into your code.",
  "version": "0.0.3",
  "license": "MIT",
  "publisher": "codershubinc",
  "repository": {
    "type": "git",
    "url": "https://github.com/codershubinc/icon-forge.git"
  },
  "qna": "https://github.com/codershubinc/icon-forge/discussions",
  "sponsor": {
    "url": "https://github.com/sponsors/codershubinc"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Snippets",
    "Visualization"
  ],
  "keywords": [
    "icons",
    "icon",
    "iconforge",
    "devicons",
    "dev-icons",
    "svg",
    "svg-snippets",
    "react-icons",
    "ui-icons",
    "web-icons",
    "icon-search",
    "icon-library",
    "icon-pack",
    "symbols",
    "glyphs",
    "vector",
    "frontend",
    "ui",
    "ux",
    "design",
    "react",
    "nextjs",
    "tailwindcss",
    "lucide",
    "material-design",
    "material-icons",
    "heroicons",
    "phosphor",
    "fontawesome",
    "bootstrap-icons",
    "remix-icon",
    "ionicons",
    "feather-icons",
    "octicons"
  ],
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "icon": "media/icon-forge.png",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "iconforge.activeTab.icons",
        "title": "Icons",
        "category": "IconForge",
        "icon": "$(list-selection)"
      },
      {
        "command": "iconforge.activeTab.badges",
        "title": "Badges",
        "category": "IconForge",
        "icon": "$(list-selection)"
      },
      {
        "command": "iconforge.selectTabFromTitle",
        "title": "Select Tab",
        "category": "IconForge",
        "icon": "$(list-selection)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "iconforge.activeTab.icons",
          "when": "view == iconforge.mainView && iconforge.activeTab == icons",
          "group": "navigation@1"
        },
        {
          "command": "iconforge.activeTab.badges",
          "when": "view == iconforge.mainView && iconforge.activeTab == badges",
          "group": "navigation@1"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "iconforge-sidebar",
          "title": "IconForge",
          "icon": "media/icon-forge.svg"
        }
      ]
    },
    "views": {
      "iconforge-sidebar": [
        {
          "icon": "media/icon-forge.svg",
          "type": "webview",
          "id": "iconforge.mainView",
          "name": "IconForge"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && npm run build:tailwind && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tailwind": "tailwindcss -i ./src/webview/styles.css -o ./dist/webview.css --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && npm run build:tailwind -- --minify && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "build:tailwind": "tailwindcss -i ./src/webview/styles.css -o ./dist/webview.css",
    "lint": "eslint src",
    "test": "vscode-test",
    "package-extension": "bun run package  && vsce package && code-insiders --install-extension iconforge-0.0.1.vsix  --force"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}