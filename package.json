{
  "name": "iconforge",
  "displayName": "IconForge",
  "description": "Get all free icons in one place.",
  "version": "0.0.1",
  "license": "MIT",
  "publisher": "codershubinc",
  "repository": {
    "type": "git",
    "url": "https://github.com/swap/icon-forge.git"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "iconforge-sidebar",
          "title": "IconForge",
          "icon": "media/icon-forge.svg"
        }
      ]
    },
    "views": {
      "iconforge-sidebar": [
        {
          "icon": "media/icon-forge.svg",
          "type": "webview",
          "id": "iconforge.mainView",
          "name": "IconForge"
        }
      ]
    },
    "commands": [
      {
        "command": "iconforge.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && npm run build:tailwind && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tailwind": "tailwindcss -i ./src/webview/styles.css -o ./dist/webview.css --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && npm run build:tailwind -- --minify && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "build:tailwind": "tailwindcss -i ./src/webview/styles.css -o ./dist/webview.css",
    "lint": "eslint src",
    "test": "vscode-test",
    "package-extension": "bun run package  && vsce package && code-insiders --install-extension iconforge-0.0.1.vsix  --force"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}